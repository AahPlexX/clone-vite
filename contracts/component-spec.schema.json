{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clone-vite.local/contracts/component-spec.schema.json",
  "title": "clone-vite component specification",
  "description": "Evidence-backed implementation contract for one reconstructed component.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "sourceSectionId",
    "targetFile",
    "screenshotPaths",
    "interactionModel",
    "dom",
    "computedStyles",
    "states",
    "assets",
    "textContent",
    "responsive"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "sourceSectionId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "targetFile": {
      "type": "string",
      "pattern": "^src/components/[A-Za-z0-9/_-]+\\.tsx$"
    },
    "screenshotPaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^docs/research/[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?/screenshots/[A-Za-z0-9._/-]+\\.(png|webp|jpg|jpeg)$"
      }
    },
    "interactionModel": {
      "type": "string",
      "enum": ["static", "click-driven", "scroll-driven", "time-driven", "mixed"]
    },
    "stateCapture": {
      "description": "Whether all non-default states have been captured for this component.",
      "type": "string",
      "enum": ["pending", "complete", "not-applicable"]
    },
    "responsiveBreakpoints": {
      "description": "Pixel widths at which the component layout changes, discovered during responsive sweep.",
      "type": "array",
      "items": { "type": "integer", "minimum": 1 }
    },
    "dom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "selector": { "type": "string", "minLength": 1 }
      }
    },
    "computedStyles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": { "type": "string", "minLength": 1 }
      }
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "trigger", "before", "after", "transition", "implementation"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "trigger": { "type": "string", "minLength": 1 },
          "before": {
            "type": "object",
            "additionalProperties": { "type": "string", "minLength": 1 }
          },
          "after": {
            "type": "object",
            "additionalProperties": { "type": "string", "minLength": 1 }
          },
          "transition": { "type": "string", "minLength": 1 },
          "implementation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["localPath", "purpose"],
        "properties": {
          "localPath": { "type": "string", "pattern": "^public/[A-Za-z0-9._/-]+$" },
          "purpose": { "type": "string", "minLength": 1 }
        }
      }
    },
    "textContent": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "responsive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["desktop", "tablet", "mobile"],
      "properties": {
        "desktop": { "type": "string", "minLength": 1 },
        "tablet": { "type": "string", "minLength": 1 },
        "mobile": { "type": "string", "minLength": 1 }
      }
    }
  }
}
