{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clone-vite.local/contracts/run.schema.json",
  "title": "clone-vite research run",
  "description": "Evidence captured for one authorized target before implementation begins.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "target",
    "capturedAt",
    "status",
    "viewports",
    "screenshots",
    "topology",
    "assets",
    "componentSpecs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "hostname", "authorized"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "hostname": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
        },
        "authorized": { "const": true }
      }
    },
    "capturedAt": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["recon-complete", "ready-to-build", "built", "qa-complete"]
    },
    "viewports": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "width", "height"],
        "properties": {
          "name": { "type": "string", "enum": ["desktop", "tablet", "mobile"] },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "screenshots": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["viewport", "path", "fullPage"],
        "properties": {
          "viewport": { "type": "string", "enum": ["desktop", "tablet", "mobile"] },
          "path": {
            "type": "string",
            "pattern": "^docs/design-references/[A-Za-z0-9._/-]+\\.(png|webp|jpg|jpeg)$"
          },
          "fullPage": { "type": "boolean" }
        }
      }
    },
    "topology": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "order", "selector", "interactionModel"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "order": { "type": "integer", "minimum": 0 },
          "selector": { "type": "string", "minLength": 1 },
          "interactionModel": {
            "type": "string",
            "enum": ["static", "click-driven", "scroll-driven", "time-driven", "mixed"]
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceUrl", "kind", "localPath"],
        "properties": {
          "sourceUrl": { "type": "string", "format": "uri" },
          "kind": { "type": "string", "enum": ["image", "video", "font", "svg", "favicon"] },
          "localPath": { "type": "string", "pattern": "^public/[A-Za-z0-9._/-]+$" }
        }
      }
    },
    "componentSpecs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^components/[a-z0-9]+(?:-[a-z0-9]+)*\\.json$"
      }
    }
  }
}
